<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015" author="quantshine">
        <createTable tableName="commodity_trade_history">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fund_code" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="symbol" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="name_tr" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="type" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
            <column name="lot" type="DECIMAL(15,4)">
                <constraints nullable="false"/>
            </column>
            <column name="price_usd" type="DECIMAL(15,4)">
                <constraints nullable="false"/>
            </column>
            <column name="usdtry_rate" type="DECIMAL(10,4)">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount_try" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="trade_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_cth_fund_code" tableName="commodity_trade_history">
            <column name="fund_code"/>
        </createIndex>

        <createIndex indexName="idx_cth_trade_date" tableName="commodity_trade_history">
            <column name="trade_date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="commodity_trade_history"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
