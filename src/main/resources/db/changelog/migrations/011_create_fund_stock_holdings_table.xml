<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011" author="quantshine">
        <createTable tableName="fund_stock_holdings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fund_code" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="stock_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="lot_count" type="DECIMAL(15,4)">
                <constraints nullable="false"/>
            </column>
            <column name="avg_cost" type="DECIMAL(10,4)">
                <constraints nullable="false"/>
            </column>
            <column name="total_cost" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="current_value" type="DECIMAL(15,2)">
                <constraints nullable="true"/>
            </column>
            <column name="purchase_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Foreign Key Constraint -->
        <addForeignKeyConstraint
                baseTableName="fund_stock_holdings"
                baseColumnNames="stock_id"
                constraintName="fk_fund_stock_holdings_stock"
                referencedTableName="stocks"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <!-- Index ekleme -->
        <createIndex indexName="idx_fund_code" tableName="fund_stock_holdings">
            <column name="fund_code"/>
        </createIndex>

        <createIndex indexName="idx_stock_id" tableName="fund_stock_holdings">
            <column name="stock_id"/>
        </createIndex>

        <!-- Composite Index (Fon + Hisse için hızlı arama) -->
        <createIndex indexName="idx_fund_stock_composite" tableName="fund_stock_holdings">
            <column name="fund_code"/>
            <column name="stock_id"/>
        </createIndex>
        <rollback>
            <dropTable tableName="fund_stock_holdings"/>
        </rollback>
    </changeSet>

</databaseChangeLog>