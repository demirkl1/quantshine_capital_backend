<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- ① Temel funds tablosunu oluştur -->
    <changeSet id="20260212-0-create-funds" author="demir">
        <createTable tableName="funds">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fund_code" type="VARCHAR(10)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="fund_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="current_price" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="last_update" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- ② cash_balance kolonu ekle -->
    <changeSet id="20260212-1" author="demir">
        <addColumn tableName="funds">
            <column name="cash_balance" type="DECIMAL(19,2)" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <update tableName="funds">
            <column name="cash_balance" value="500000.00"/>
            <where>fund_code = 'HSF'</where>
        </update>

        <update tableName="funds">
            <column name="cash_balance" value="300000.00"/>
            <where>fund_code = 'TEK'</where>
        </update>

        <update tableName="funds">
            <column name="cash_balance" value="400000.00"/>
            <where>fund_code = 'MF'</where>
        </update>

        <rollback>
            <dropColumn tableName="funds" columnName="cash_balance"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
