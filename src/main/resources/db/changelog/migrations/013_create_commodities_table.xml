<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="013" author="quantshine">
        <createTable tableName="commodities">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="symbol" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name_tr" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="current_price" type="DECIMAL(12,4)">
                <constraints nullable="true"/>
            </column>
            <column name="change" type="DECIMAL(10,4)">
                <constraints nullable="true"/>
            </column>
            <column name="change_percent" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
            <column name="last_update" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="commodities"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
