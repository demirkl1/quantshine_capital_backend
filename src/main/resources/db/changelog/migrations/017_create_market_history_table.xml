<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="017" author="quantshine">
        <createTable tableName="market_history">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="symbol" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="close" type="DECIMAL(18,4)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="market_history"
                columnNames="symbol, date"
                constraintName="uq_market_history_symbol_date"/>

        <createIndex indexName="idx_market_history_symbol_date" tableName="market_history">
            <column name="symbol"/>
            <column name="date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="market_history"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
